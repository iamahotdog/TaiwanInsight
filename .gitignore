# ======= GitHub Pages / Web Project Gitignore =======

# Dependency directories
node_modules/

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Python (Local Data Engineering Scripts)
__pycache__/
*.py[cod]
*$py.class
convert.py
force_convert.py
extract_data.py

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# (Notice: .csv, .html, .css, .js are explicitly NOT ignored so they can be pushed to GitHub)
